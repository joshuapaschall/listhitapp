# --- App / site ---
NEXT_PUBLIC_SITE_URL=https://app.example.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
DISPOTOOL_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MEDIA_BASE_URL=
SITE_URL=http://localhost:3000
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_DEV_MODE=0
NEXT_PUBLIC_DEV_BYPASS_AGENT_AUTH=0

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_URL=https://your-supabase-project.supabase.co
CRON_SECRET= # shared secret used by Supabase pg_cron, Gmail sync, and edge functions to call protected endpoints (generate with: openssl rand -hex 32; set in Vercel and Supabase secrets; never commit real value)
ADMIN_TASKS_TOKEN= # generate with: openssl rand -hex 32

# --- Telnyx ---
TELNYX_API_URL=https://api.telnyx.com/v2
TELNYX_API_KEY=your-telnyx-api-key
TELNYX_PUBLIC_KEY=
TELNYX_MESSAGING_PROFILE_ID=

# --- SMS compliance ---
# Auto-reply text sent when inbound SMS is classified as HELP/INFO/SUPPORT.
SMS_HELP_AUTO_REPLY=ListHit notifications. Msg & data rates may apply. Reply STOP to cancel. Contact: support@listhit.io
TELNYX_CALL_CONTROL_APP_ID=
TELNYX_VOICE_CONNECTION_ID=
VOICE_CONNECTION_ID=
CALL_CONTROL_APP_ID= # Voice connection ID; VOICE_CONNECTION_ID and TELNYX_VOICE_CONNECTION_ID fall back here
TELNYX_SIP_CONNECTION_ID=
TELNYX_SIP_CREDENTIAL_CONNECTION_ID=
SIP_CONNECTION_ID=
SIP_CREDENTIAL_CONNECTION_ID=
TELNYX_PHONE_NUMBER=
FALLBACK_AGENT_SIP_USERNAME=sip_demo_user
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000000
DEFAULT_OUTBOUND_DID=+15555550123 # Fallback SMS DID when no thread context exists
FROM_NUMBER=+15555550123
NEXT_PUBLIC_FROM_NUMBER=+15555550123 # Public fallback caller ID for browser voice UI
TELNYX_DEBUG=0
TELNYX_GLOBAL_MPS=
TELNYX_CARRIER_MPS=
TELNYX_TMO_DAILY_LIMIT=
SKIP_TELNYX_SIG=0

# --- SMS queue tuning ---
SMS_QUEUE_CONCURRENCY=5 # Maximum SMS jobs claimed per worker run
SMS_QUEUE_MAX_ATTEMPTS=8 # Maximum SMS send attempts before marking a job dead
SMS_QUEUE_LEASE_SECONDS=300 # Seconds an SMS worker owns a leased job
SMS_QUEUE_BASE_BACKOFF_MS=2000 # Base exponential backoff delay for SMS retries
SMS_QUEUE_JITTER_MS=500 # Random jitter added to SMS retry backoff
SMS_QUEUE_WORKER_ID= # Optional stable worker ID for SMS queue leases

# --- Voice sync ---
VOICE_SYNC_SECRET_KEY=

# --- Native short link service (replaces Short.io) ---
# Comma-separated list of branded short-link domains (DNS should CNAME each to cname.vercel-dns.com)
SHORT_LINK_DOMAINS=
# Default domain used when creating new short links (must be one of SHORT_LINK_DOMAINS)
SHORT_LINK_DEFAULT_DOMAIN=

# --- Google / Gmail ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_FROM=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=
# /api/gmail/sync-cron cycles gmail_tokens without needing a hardcoded userId when CRON_SECRET is set

# --- AWS SES ---
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=
AWS_SES_FROM_NAME=
AWS_SES_CONFIGURATION_SET=
AWS_SES_DISABLE_CUSTOM_HEADERS=0 # Set to 1 to omit custom SES tracking headers
AWS_SNS_TOPIC_ARN=
EMAIL_UNSUBSCRIBE_SECRET=
EMAIL_PHYSICAL_ADDRESS=ListHit CRM, 123 Main St, Anytown, USA
EMAIL_DISABLE_SHORTLINKS=1

# --- Email delivery ---
# Delay between individual email sends to throttle provider requests (ms)
EMAIL_SEND_DELAY_MS=750
# Base backoff delay between retry attempts when SES rate limits occur (ms)
EMAIL_RETRY_BACKOFF_MS=2000
# Maximum retry attempts for SES rate limit responses before marking as failed
EMAIL_RATE_MAX_RETRY=3
EMAIL_RATE_HEADROOM=0.8 # Fraction of provider rate limit to use when pacing sends
EMAIL_SPACING_MS_MIN=0 # Minimum randomized spacing between rate-limited sends (ms)
EMAIL_SPACING_MS_MAX=2000 # Maximum randomized spacing between rate-limited sends (ms)
EMAIL_QUEUE_CONCURRENCY=2
EMAIL_QUEUE_WORKER_ID=
EMAIL_QUEUE_LEASE_SECONDS=300
EMAIL_QUEUE_MAX_ATTEMPTS=8
EMAIL_QUEUE_BASE_BACKOFF_MS=2000
EMAIL_QUEUE_JITTER_MS=500

# --- SendFox ---
SENDFOX_API_TOKEN=                        # Canonical personal access token from sendfox.com/account/oauth
SENDFOX_API_KEY=                          # Deprecated legacy alias; code falls back to this only when SENDFOX_API_TOKEN is unset
SENDFOX_DEFAULT_LIST_ID=                  # SendFox list ID that new buyers are auto-added to
SENDFOX_DELETED_LIST_ID=                  # SendFox list ID used to park deleted/soft-deleted buyers
SENDFOX_WEBHOOK_TOKEN=                    # Shared secret for /api/webhooks/sendfox (openssl rand -hex 32)
SENDFOX_RATE_BACKOFF_MS=2000               # Legacy SendFox retry backoff alias used when EMAIL_RETRY_BACKOFF_MS is unset
SENDFOX_RATE_MAX_RETRY=3                   # Legacy SendFox max retry alias used when EMAIL_RATE_MAX_RETRY is unset
SENDFOX_SEND_DELAY_MS=750                  # Legacy SendFox send delay alias used when EMAIL_SEND_DELAY_MS is unset
SENDFOX_CLIENT_ID=                        # Optional: OAuth client ID (only needed for multi-user OAuth flow)
SENDFOX_CLIENT_SECRET=                    # Optional: OAuth client secret
NEXT_PUBLIC_SENDFOX_REDIRECT_URI=         # Optional: public OAuth redirect URI (must match SendFox OAuth client config)
SENDFOX_REDIRECT_URI=                      # Optional: server-side OAuth redirect URI fallback
NEXT_PUBLIC_SENDFOX_DEFAULT_LIST_ID=      # Mirror of SENDFOX_DEFAULT_LIST_ID for client-side fallback

# --- AI ---
OPENAI_API_KEY=

# --- Media processing ---
FFMPEG_PATH=

APP_TIMEZONE=America/New_York  # IANA timezone for formatting dates in notifications

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=ListHit <notifications@listhit.io>

# --- ListHit feature flags ---
LISTHIT_DRY_RUN=
NEXT_PUBLIC_DEFAULT_OUTBOUND_DID=

# Number pool config for SMS compose UI. Fallback only. Live values come from /api/messaging/throughput which reads from voice_numbers.messaging_profile_id. Run /api/sync/voice-numbers (or wait for the nightly cron) to populate.
NEXT_PUBLIC_LISTHIT_POOL_SIZE=15
NEXT_PUBLIC_LISTHIT_PER_NUMBER_MPM=2

# --- DeBounce email validation ---
DEBOUNCE_API_KEY=your-debounce-private-key
# --- Signup validation policy ---
ALLOW_VOIP_SIGNUPS=false
